# NersLink Platform - .env Configuration
# Copy from .env.example and customize for your environment

# Application
APP_NAME="NersLink Platform"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/nerslink

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nerslink
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_DRIVER=files
SESSION_LIFETIME=120
SESSION_SECURE=false

# Security
HASH_COST=12
MFA_ENABLED=false
